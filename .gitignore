# Local secrets
/wp-config.php
/.env
/.env.*

# WordPress backups, caches, logs, and temporary files
/wp-content/wpvividbackups/
/wp-content/wflogs/
/wp-content/cache/
/wp-content/upgrade/
/wp-content/ai1wm-backups/
/wp-content/backups/
*.sql
*.zip
*.tar
*.tar.gz
*.tgz
*.log

# Next.js dependencies and generated output
/public/node_modules/
/public/.next/
/public/out/
/public/.vercel/
/public/.snowflake/
/public/.v0-trash/
/public/.env*.local

# Deployee runtime settings and generated database backups
/deployee/storage/*
!/deployee/storage/.gitignore
!/deployee/storage/.htaccess
